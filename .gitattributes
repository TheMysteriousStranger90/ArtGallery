# ─── Default behaviour ────────────────────────────────────────────────────────
* text=auto eol=lf

# ─── C# / .NET source ─────────────────────────────────────────────────────────
*.cs          text eol=lf diff=csharp
*.csx         text eol=lf diff=csharp
*.razor       text eol=lf
*.cshtml      text eol=lf

# ─── MSBuild / project files ─────────────────────────────────────────────────
*.csproj      text eol=lf
*.vbproj      text eol=lf
*.fsproj      text eol=lf
*.vcxproj     text eol=lf
*.proj        text eol=lf
*.props       text eol=lf
*.targets     text eol=lf
*.sln         text eol=lf eol=crlf   merge=union
*.slnx        text eol=lf

# ─── Config / markup ──────────────────────────────────────────────────────────
*.json        text eol=lf
*.jsonc       text eol=lf
*.xml         text eol=lf diff=xml
*.config      text eol=lf
*.nuspec      text eol=lf
*.resx        text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.ini         text eol=lf
*.env         text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore    text eol=lf

# ─── Web / Blazor client ─────────────────────────────────────────────────────
*.html        text eol=lf diff=html
*.htm         text eol=lf diff=html
*.css         text eol=lf
*.scss        text eol=lf
*.less        text eol=lf
*.js          text eol=lf
*.ts          text eol=lf
*.jsx         text eol=lf
*.tsx         text eol=lf
*.svg         text eol=lf

# ─── Scripts ─────────────────────────────────────────────────────────────────
*.sh          text eol=lf
*.bash        text eol=lf
*.ps1         text eol=lf
*.psm1        text eol=lf
*.psd1        text eol=lf

# ─── Dockerfile ───────────────────────────────────────────────────────────────
Dockerfile    text eol=lf
*.dockerfile  text eol=lf
docker-compose*.yml text eol=lf
.dockerignore text eol=lf
nginx.conf    text eol=lf

# ─── Documentation ───────────────────────────────────────────────────────────
*.md          text eol=lf
*.txt         text eol=lf
LICENSE       text eol=lf

# ─── Binary files (never delta/merge) ────────────────────────────────────────
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.webp        binary
*.bmp         binary
*.tiff        binary
*.pdf         binary
*.zip         binary
*.gz          binary
*.tar         binary
*.7z          binary
*.rar         binary
*.exe         binary
*.dll         binary
*.pdb         binary
*.pfx         binary
*.cer         binary
*.p12         binary
*.nupkg       binary
*.snupkg      binary
*.wasm        binary
*.db          binary
*.sqlite      binary
