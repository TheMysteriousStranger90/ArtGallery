@namespace ArtGallery.ClientApp.Layout

<footer class="app-footer mt-auto">
    <div class="footer-content">
        <div class="container-fluid px-4">
            <div class="row align-items-center py-3">
                <div class="col-md-4 text-center text-md-start mb-2 mb-md-0">
                    <span class="footer-brand">
                        <i class="bi bi-palette-fill me-2" aria-hidden="true"></i>Art Gallery
                    </span>
                </div>
                <div class="col-md-4 text-center mb-2 mb-md-0">
                    <nav aria-label="Footer navigation" class="footer-links">
                        <a href="/gallery" class="footer-link">Gallery</a>
                        <a href="/artists" class="footer-link">Artists</a>
                        <a href="/exhibitions" class="footer-link">Exhibitions</a>
                        <a href="/privacy" class="footer-link">Privacy</a>
                        <a href="/terms" class="footer-link">Terms</a>
                    </nav>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <small class="text-muted">&copy; @DateTime.UtcNow.Year Art Gallery. All rights reserved.</small>
                </div>
            </div>
        </div>
    </div>
</footer>
