@using ArtGallery.ClientApp.Services
@using ArtGallery.ClientApp.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject IPaintingService PaintingService
@inject FavoritesStateService FavoritesState
@inject ToastService Toast
@inject ILogger<PaintingCard> Logger
@inject NavigationManager NavigationManager

<!-- Image -->
<div class="card-img-container">
    <a href="/paintings/@Painting?.Id" tabindex="-1" aria-hidden="true">
        @if (!string.IsNullOrEmpty(Painting?.ImageUrl))
        {
            <img src="@Painting.ImageUrl"
                 class="card-img-top"
                 alt="@Painting!.Title"
                 loading="lazy"
                 width="400" height="300"/>
        }
        else
        {
            <div class="card-img-placeholder" aria-label="No image available">
                <i class="bi bi-image text-muted fs-2" aria-hidden="true"></i>
                <span>No Image</span>
            </div>
        }
    </a>
</div>

<!-- Body -->
<div class="card-body d-flex flex-column text-center">
    <h5 class="card-title mb-1">
        <a href="/paintings/@Painting?.Id" class="text-decoration-none stretched-link-text">
            @Painting?.Title
        </a>
    </h5>
    <p class="card-text small text-muted mb-1">
        <i class="bi bi-person me-1" aria-hidden="true"></i>@Painting?.Artist.FullName
    </p>
    @if (Painting?.CreationYear > 0)
    {
        <p class="card-text small text-muted mb-1">
            <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>@Painting.CreationYear
        </p>
    }
    @if (!string.IsNullOrEmpty(Painting?.Genre?.Name))
    {
        <span class="badge genre-badge mt-1">@Painting.Genre.Name</span>
    }
</div>

<!-- Footer -->
<div class="card-footer">
    <a href="/paintings/@Painting?.Id" class="btn btn-outline-primary btn-sm w-100 mb-2">
        <i class="bi bi-eye me-1" aria-hidden="true"></i> View Details
    </a>

    @if (_isAdministrator)
    {
        <div class="d-flex gap-1 mb-2">
            <a href="/admin/paintings/edit/@Painting?.Id" class="btn btn-outline-secondary btn-sm flex-fill">
                <i class="bi bi-pencil me-1" aria-hidden="true"></i>Edit
            </a>
            <button class="btn btn-outline-danger btn-sm flex-fill"
                    @onclick="DeletePainting"
                    disabled="@_isDeleting"
                    aria-label="Delete @Painting?.Title">
                @if (_isDeleting)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-trash" aria-hidden="true"></i>
                }
            </button>
        </div>
    }

    @if (_isAuthenticated)
    {
        @if (OnRemoveFavorite.HasDelegate)
        {
            <button class="btn btn-outline-danger btn-sm w-100"
                    @onclick="RemoveFromFavourites"
                    disabled="@_isRemoving"
                    aria-label="Remove from favourites">
                @if (_isRemoving)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-heart-break me-1" aria-hidden="true"></i> @("Remove from Favourites")
                }
            </button>
        }
        else
        {
            <button class="btn @(_isFavorite ? "btn-favorite-active" : "btn-outline-primary") btn-sm w-100"
                    @onclick="ToggleFavorite"
                    disabled="@(_isFavoriteLoading || _isFavorite)"
                    aria-label="@(_isFavorite ? "Already in favourites" : "Add to favourites")">
                @if (_isFavoriteLoading)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi @(_isFavorite ? "bi-heart-fill" : "bi-heart") me-1" aria-hidden="true"></i>
                    @(_isFavorite ? "In Favourites" : "Add to Favourites")
                }
            </button>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public PaintingDto? Painting { get; set; }
    [Parameter] public EventCallback<Guid> OnPaintingDeleted { get; set; }
    [Parameter] public EventCallback<Guid> OnRemoveFavorite { get; set; }

    private bool _isAuthenticated;
    private bool _isAdministrator;
    private bool _isFavorite;
    private bool _isFavoriteLoading;
    private bool _isDeleting;
    private bool _isRemoving;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        _isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        _isAdministrator = user.IsInRole("Administrator");

        // Read from cached state — zero API calls per card
        if (_isAuthenticated && Painting is not null)
            _isFavorite = FavoritesState.IsPaintingFavorite(Painting.Id);
    }

    private async Task ToggleFavorite()
    {
        if (Painting is null || _isFavoriteLoading || _isFavorite) return;
        _isFavoriteLoading = true;
        try
        {
            var ok = await PaintingService.AddPaintingToFavoritesAsync(Painting.Id);
            if (ok)
            {
                _isFavorite = true;
                FavoritesState.MarkPaintingFavorite(Painting.Id);
                Toast.Success($"\"{Painting.Title}\" added to favourites.");
            }
            else
            {
                Toast.Error("Could not add to favourites. Please try again.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to add painting {Id} to favourites", Painting.Id);
            Toast.Error("An error occurred.");
        }
        finally
        {
            _isFavoriteLoading = false;
        }
    }

    private async Task RemoveFromFavourites()
    {
        if (Painting is null || _isRemoving) return;
        _isRemoving = true;
        try
        {
            var ok = await PaintingService.RemovePaintingFromFavoritesAsync(Painting.Id);
            if (ok)
            {
                FavoritesState.UnmarkPaintingFavorite(Painting.Id);
                Toast.Success($"\"{Painting.Title}\" removed from favourites.");
                await OnRemoveFavorite.InvokeAsync(Painting.Id);
            }
            else
            {
                Toast.Error("Could not remove from favourites. Please try again.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to remove painting {Id} from favourites", Painting.Id);
            Toast.Error("An error occurred.");
        }
        finally
        {
            _isRemoving = false;
        }
    }

    private async Task DeletePainting()
    {
        if (Painting is null || _isDeleting) return;
        _isDeleting = true;
        try
        {
            var ok = await PaintingService.DeletePaintingAsync(Painting.Id);
            if (ok)
            {
                Toast.Success($"\"{Painting.Title}\" deleted.");
                await OnPaintingDeleted.InvokeAsync(Painting.Id);
            }
            else
            {
                Toast.Error("Delete failed. Please try again.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete painting {Id}", Painting.Id);
            Toast.Error("An error occurred while deleting.");
        }
        finally
        {
            _isDeleting = false;
        }
    }

}