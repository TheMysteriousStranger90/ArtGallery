@namespace ArtGallery.ClientApp.Shared

<div class="empty-state" role="status">
    <div class="empty-state-icon">
        <i class="@Icon" aria-hidden="true"></i>
    </div>
    <h4 class="empty-state-title">@Title</h4>
    <p class="empty-state-message">@Message</p>
    @if (ChildContent is not null)
    {
        <div class="mt-3">@ChildContent</div>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = "bi bi-search fs-1";
    [Parameter] public string Title { get; set; } = "No Results Found";
    [Parameter] public string Message { get; set; } = "Try adjusting your filters or search terms.";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
