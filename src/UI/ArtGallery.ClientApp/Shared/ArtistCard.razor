@using ArtGallery.ClientApp.Services
@using ArtGallery.ClientApp.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject IArtistService ArtistService
@inject FavoritesStateService FavoritesState
@inject ToastService Toast
@inject ILogger<ArtistCard> Logger

<!-- Image -->
<div class="card-img-container">
    <a href="/artists/@Artist?.Id" tabindex="-1" aria-hidden="true">
        @if (!string.IsNullOrEmpty(Artist?.PictureUrl))
        {
            <img src="@Artist.PictureUrl"
                 class="card-img-top"
                 alt="@Artist!.FullName"
                 loading="lazy"
                 width="400" height="300"/>
        }
        else
        {
            <div class="card-img-placeholder" aria-label="No portrait available">
                <i class="bi bi-person-circle text-muted fs-2" aria-hidden="true"></i>
                <span>No Image</span>
            </div>
        }
    </a>
</div>

<!-- Body -->
<div class="card-body d-flex flex-column text-center">
    <h5 class="card-title mb-1">
        <a href="/artists/@Artist?.Id" class="text-decoration-none">@Artist?.FullName</a>
    </h5>
    @if (!string.IsNullOrEmpty(Artist?.Nationality))
    {
        <p class="card-text small text-muted mb-1">
            <i class="bi bi-globe me-1" aria-hidden="true"></i>@Artist.Nationality
        </p>
    }
    @if (Artist?.BirthDate.HasValue == true)
    {
        <p class="card-text small text-muted mb-1">
            <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>
            @Artist.BirthDate.Value.Year
            @if (Artist.DeathDate.HasValue)
            {
                <span> – @Artist.DeathDate.Value.Year</span>
            }
        </p>
    }
</div>

<!-- Footer -->
<div class="card-footer">
    <a href="/artists/@Artist?.Id" class="btn btn-outline-primary btn-sm w-100 mb-2">
        <i class="bi bi-eye me-1" aria-hidden="true"></i> View Profile
    </a>

    @if (_isAdministrator)
    {
        <div class="d-flex gap-1 mb-2">
            <a href="/admin/artists/edit/@Artist?.Id" class="btn btn-outline-secondary btn-sm flex-fill">
                <i class="bi bi-pencil" aria-hidden="true"></i>
            </a>
            <button class="btn btn-outline-danger btn-sm flex-fill"
                    @onclick="DeleteArtist"
                    disabled="@_isDeleting"
                    aria-label="Delete @Artist?.FullName">
                @if (_isDeleting)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-trash" aria-hidden="true"></i>
                }
            </button>
        </div>
    }

    @if (_isAuthenticated)
    {
        @if (OnRemoveFavorite.HasDelegate)
        {
            <button class="btn btn-outline-danger btn-sm w-100"
                    @onclick="RemoveFromFavourites"
                    disabled="@_isRemoving"
                    aria-label="Remove from favourites">
                @if (_isRemoving)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-heart-break me-1" aria-hidden="true"></i> @("Remove from Favourites")
                }
            </button>
        }
        else
        {
            <button class="btn @(_isFavorite ? "btn-favorite-active" : "btn-outline-primary") btn-sm w-100"
                    @onclick="ToggleFavorite"
                    disabled="@(_isFavoriteLoading || _isFavorite)"
                    aria-label="@(_isFavorite ? "Already in favourites" : "Add to favourites")">
                @if (_isFavoriteLoading)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi @(_isFavorite ? "bi-heart-fill" : "bi-heart") me-1" aria-hidden="true"></i>
                    @(_isFavorite ? "In Favourites" : "Add to Favourites")
                }
            </button>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public ArtistDto? Artist { get; set; }
    [Parameter] public EventCallback<Guid> OnArtistDeleted { get; set; }
    [Parameter] public EventCallback<Guid> OnRemoveFavorite { get; set; }

    private bool _isAuthenticated;
    private bool _isAdministrator;
    private bool _isFavorite;
    private bool _isFavoriteLoading;
    private bool _isDeleting;
    private bool _isRemoving;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        _isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        _isAdministrator = user.IsInRole("Administrator");

        // Read from cached state — zero API calls per card
        if (_isAuthenticated && Artist is not null)
            _isFavorite = FavoritesState.IsArtistFavorite(Artist.Id);
    }

    private async Task ToggleFavorite()
    {
        if (Artist is null || _isFavoriteLoading || _isFavorite) return;
        _isFavoriteLoading = true;
        try
        {
            var ok = await ArtistService.AddArtistToFavoritesAsync(Artist.Id);
            if (ok)
            {
                _isFavorite = true;
                FavoritesState.MarkArtistFavorite(Artist.Id);
                Toast.Success($"\"{Artist.FullName}\" added to favourites.");
            }
            else
            {
                Toast.Error("Could not add to favourites. Please try again.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to add artist {Id} to favourites", Artist.Id);
            Toast.Error("An error occurred.");
        }
        finally
        {
            _isFavoriteLoading = false;
        }
    }

    private async Task RemoveFromFavourites()
    {
        if (Artist is null || _isRemoving) return;
        _isRemoving = true;
        try
        {
            var ok = await ArtistService.RemoveArtistFromFavoritesAsync(Artist.Id);
            if (ok)
            {
                FavoritesState.UnmarkArtistFavorite(Artist.Id);
                Toast.Success($"\"{Artist.FullName}\" removed from favourites.");
                await OnRemoveFavorite.InvokeAsync(Artist.Id);
            }
            else
            {
                Toast.Error("Could not remove from favourites. Please try again.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to remove artist {Id} from favourites", Artist.Id);
            Toast.Error("An error occurred.");
        }
        finally
        {
            _isRemoving = false;
        }
    }

    private async Task DeleteArtist()
    {
        if (Artist is null || _isDeleting) return;
        _isDeleting = true;
        try
        {
            var ok = await ArtistService.DeleteArtistAsync(Artist.Id);
            if (ok)
            {
                Toast.Success($"\"{Artist.FullName}\" deleted.");
                await OnArtistDeleted.InvokeAsync(Artist.Id);
            }
            else
            {
                Toast.Error("Delete failed.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete artist {Id}", Artist.Id);
            Toast.Error("An error occurred.");
        }
        finally
        {
            _isDeleting = false;
        }
    }

}