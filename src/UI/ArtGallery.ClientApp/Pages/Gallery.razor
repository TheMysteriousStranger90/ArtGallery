@page "/gallery"
@using ArtGallery.ClientApp.Services
@using ArtGallery.ClientApp.Services.Interfaces
@using ArtGallery.ClientApp.Shared
@using Microsoft.AspNetCore.Components.Authorization
@inject IPaintingService PaintingService
@inject FavoritesStateService FavoritesState
@inject ToastService Toast
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Gallery> Logger
@inject IClient ApiClient

<PageTitle>Painting Gallery – Art Gallery</PageTitle>

<div class="gallery-container">
    <h1 class="gallery-page-title">Painting Gallery</h1>

    <div class="gallery-controls mb-4">
        <div class="row align-items-end">
            <div class="col-md-9">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Search by title…"
                           aria-label="Search paintings"
                           @bind="CurrentSearch" @bind:event="oninput" @onkeyup="HandleKeyUp"/>
                    <button class="btn btn-outline-primary" type="button" @onclick="ApplySearch">
                        <i class="bi bi-search me-1" aria-hidden="true"></i> Search
                    </button>
                    @if (!string.IsNullOrEmpty(ActiveSearch))
                    {
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch"
                                aria-label="Clear search">
                            <i class="bi bi-x-lg" aria-hidden="true"></i>
                        </button>
                    }
                </div>
            </div>
            <div class="col-md-3">
                <label for="sortOrder" class="form-label-sm">Sort by:</label>
                <select id="sortOrder" class="form-select" @bind="CurrentSort">
                    <option value="title">Title (A–Z)</option>
                    <option value="-title">Title (Z–A)</option>
                    <option value="year">Oldest first</option>
                    <option value="-year">Newest first</option>
                    <option value="artist">Artist (A–Z)</option>
                    <option value="-artist">Artist (Z–A)</option>
                </select>
            </div>
        </div>

        @if (isAdministrator)
        {
            <div class="row mt-3">
                <div class="col-12">
                    <a href="/admin/paintings/create" class="btn btn-primary w-100">
                        <i class="bi bi-plus-circle me-2" aria-hidden="true"></i> Add New Painting
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="row">
        <!-- Filter Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="filter-panel">
                <h5 class="filter-heading">Filter By</h5>

                <div class="filter-group">
                    <label for="artistFilter" class="form-label-sm">Artist</label>
                    <select id="artistFilter" class="form-select form-select-sm"
                            @bind="ArtistId" @bind:after="ApplyFilters">
                        <option value="">All Artists</option>
                        @foreach (var a in (artists ?? Enumerable.Empty<ArtistDto>()))
                        {
                            <option value="@a.Id">@a.FullName</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="genreFilter" class="form-label-sm">Genre</label>
                    <select id="genreFilter" class="form-select form-select-sm"
                            @bind="GenreId" @bind:after="ApplyFilters">
                        <option value="">All Genres</option>
                        @foreach (var g in (genres ?? Enumerable.Empty<GenreDto>()))
                        {
                            <option value="@g.Id">@g.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="museumFilter" class="form-label-sm">Museum</label>
                    <select id="museumFilter" class="form-select form-select-sm"
                            @bind="MuseumId" @bind:after="ApplyFilters">
                        <option value="">All Museums</option>
                        @foreach (var m in (museums ?? Enumerable.Empty<MuseumBriefDto>()))
                        {
                            <option value="@m.Id">@m.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label class="form-label-sm">Creation Year</label>
                    <div class="d-flex gap-2">
                        <input type="number" class="form-control form-control-sm" placeholder="From" @bind="FromYear"/>
                        <input type="number" class="form-control form-control-sm" placeholder="To" @bind="ToYear"/>
                        <button class="btn btn-sm btn-outline-primary" @onclick="ApplyFilters"
                                aria-label="Apply year filter">
                            <i class="bi bi-sliders" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                @if (HasActiveFilters)
                {
                    <div class="filter-actions mt-3">
                        <button class="btn btn-sm btn-outline-secondary w-100" @onclick="ClearAllFilters">
                            <i class="bi bi-x-circle me-1" aria-hidden="true"></i> Clear Filters
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Paintings Grid -->
        <div class="col-md-9">
            @if (isLoading)
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 mb-3">
                    @for (int i = 0; i < PageSize; i++)
                    {
                        <div class="col">
                            <div class="painting-card">
                                <SkeletonCard/>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (pagedPaintings?.Data != null && pagedPaintings.Data.Any())
            {
                <div class="gallery-stats-container mb-3">
                    <div class="gallery-stats">
                        Showing @pagedPaintings.Data.Count of @pagedPaintings.Count paintings &mdash;
                        page @CurrentPage of @TotalPages
                    </div>
                </div>

                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 mb-3">
                    @foreach (var painting in pagedPaintings.Data)
                    {
                        <div class="col">
                            <div class="painting-card">
                                <PaintingCard Painting="painting" OnPaintingDeleted="HandlePaintingDeleted"/>
                            </div>
                        </div>
                    }
                </div>

                <div class="pagination-container">
                    <Pagination CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="ChangePage"
                                AriaLabel="Paintings navigation"/>
                </div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="gallery-message">
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>@errorMessage
                    </div>
                </div>
            }
            else
            {
                <EmptyState Icon="bi bi-palette fs-1" Title="No Paintings Found"
                            Message="Try adjusting your search or filter parameters."/>
            }
        </div>
    </div>
</div>

@code {
    private Pagination_1OfOfPaintingDtoAndApplicationAnd_0AndCulture_neutralAndPublicKeyToken_null? pagedPaintings;
    private bool isLoading = true;
    private string? errorMessage;
    private bool _hasCompletedInitialParameterSet;
    private bool isAdministrator;

    private List<ArtistDto>? artists;
    private List<GenreDto>? genres;
    private List<MuseumBriefDto>? museums;

    private bool HasActiveFilters =>
        ArtistId.HasValue || GenreId.HasValue || MuseumId.HasValue || FromYear.HasValue || ToYear.HasValue;

    [Parameter] [SupplyParameterFromQuery] public int CurrentPage { get; set; } = 1;
    [Parameter] [SupplyParameterFromQuery] public int PageSize { get; set; } = 6;
    [Parameter] [SupplyParameterFromQuery] public string? ActiveSearch { get; set; }

    private string _currentSort = "title";

    [Parameter]
    [SupplyParameterFromQuery]
    public string CurrentSort
    {
        get => _currentSort;
        set
        {
            if (_currentSort != value)
            {
                _currentSort = value;
                if (_hasCompletedInitialParameterSet)
                {
                    CurrentPage = 1;
                    NavigateToPage();
                }
            }
        }
    }

    private Guid? _artistId;

    [Parameter]
    [SupplyParameterFromQuery]
    public Guid? ArtistId
    {
        get => _artistId;
        set
        {
            if (_artistId != value)
            {
                _artistId = value;
                if (_hasCompletedInitialParameterSet) ApplyFilters();
            }
        }
    }

    private Guid? _genreId;

    [Parameter]
    [SupplyParameterFromQuery]
    public Guid? GenreId
    {
        get => _genreId;
        set
        {
            if (_genreId != value)
            {
                _genreId = value;
                if (_hasCompletedInitialParameterSet)
                {
                    CurrentPage = 1;
                    NavigateToPage();
                }
            }
        }
    }

    [Parameter] [SupplyParameterFromQuery] public Guid? MuseumId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "paintType")]
    public string? PaintTypeString
    {
        get => _paintType?.ToString().Replace("_", "");
        set
        {
            PaintType? newPaintType = null;
            if (!string.IsNullOrEmpty(value))
            {
                newPaintType = value.ToLowerInvariant() switch
                {
                    "oil" => Services.PaintType._0,
                    "acrylic" => Services.PaintType._1,
                    "watercolor" => Services.PaintType._2,
                    "gouache" => Services.PaintType._3,
                    "tempera" => Services.PaintType._4,
                    "pastel" => Services.PaintType._5,
                    "encaustic" => Services.PaintType._6,
                    "fresco" => Services.PaintType._7,
                    "ink" => Services.PaintType._8,
                    "digital" => Services.PaintType._9,
                    "mixedmedia" => Services.PaintType._10,
                    "other" => Services.PaintType._11,
                    _ => null
                };
            }

            if (_paintType != newPaintType)
            {
                _paintType = newPaintType;
                if (_hasCompletedInitialParameterSet)
                {
                    CurrentPage = 1;
                    NavigateToPage();
                }
            }
        }
    }

    private PaintType? _paintType;

    public PaintType? PaintType
    {
        get => _paintType;
        set => PaintTypeString = value?.ToString();
    }

    [Parameter] [SupplyParameterFromQuery] public int? FromYear { get; set; }
    [Parameter] [SupplyParameterFromQuery] public int? ToYear { get; set; }

    public string? CurrentSearch { get; set; }

    public int TotalPages => (pagedPaintings?.Count > 0 && PageSize > 0)
        ? (int)Math.Ceiling((double)pagedPaintings.Count / PageSize)
        : 0;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdministrator = authState.User.IsInRole("Administrator");

        _currentSort = CurrentSort;
        _artistId = ArtistId;
        _genreId = GenreId;

        if (!string.IsNullOrEmpty(ActiveSearch)) CurrentSearch = ActiveSearch;

        await Task.WhenAll(
            LoadArtists(),
            LoadGenres(),
            LoadMuseums(),
            LoadFavoritesIfAuthenticated(authState.User.Identity?.IsAuthenticated ?? false)
        );
    }

    private async Task LoadFavoritesIfAuthenticated(bool isAuthenticated)
    {
        if (isAuthenticated)
            await FavoritesState.LoadPaintingFavoritesAsync();
    }

    private async Task LoadArtists()
    {
        try
        {
            var r = await ApiClient.ArtistsGET2Async(1, 100, "", "", "lastName", "1.0");
            artists = r.Data.ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading artists for filter");
            artists = new List<ArtistDto>();
        }
    }

    private async Task LoadGenres()
    {
        try
        {
            var r = await ApiClient.PaintingsGET2Async(1, 100, "", null, null, null, null, null, null, "title", "1.0");
            genres = r.Data.Where(p => p.Genre != null)
                .GroupBy(p => p.Genre.Id)
                .Select(g => g.First().Genre)
                .OrderBy(g => g.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading genres for filter");
            genres = new List<GenreDto>();
        }
    }

    private async Task LoadMuseums()
    {
        try
        {
            var r = await ApiClient.PaintingsGET2Async(1, 100, "", null, null, null, null, null, null, "title", "1.0");
            museums = r.Data.Where(p => p.Museum != null)
                .GroupBy(p => p.Museum.Id)
                .Select(g => g.First().Museum)
                .OrderBy(m => m.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading museums for filter");
            museums = new List<MuseumBriefDto>();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (CurrentPage < 1) CurrentPage = 1;
        if (PageSize < 1) PageSize = 6;

        if (string.IsNullOrEmpty(CurrentSearch) && !string.IsNullOrEmpty(ActiveSearch))
            CurrentSearch = ActiveSearch;
        else if (ActiveSearch == null && CurrentSearch != null)
            CurrentSearch = string.Empty;

        await LoadPaintings();
        _hasCompletedInitialParameterSet = true;
    }

    private async Task LoadPaintings()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var sort = CurrentSort switch
            {
                var s when s.StartsWith("-") => $"{s[1..]}_desc",
                var s when !string.IsNullOrEmpty(s) => s,
                _ => "title"
            };

            pagedPaintings = await PaintingService.GetPaintingsAsync(
                pageIndex: CurrentPage, pageSize: PageSize,
                search: ActiveSearch ?? "", sort: sort,
                artistId: ArtistId, genreId: GenreId, museumId: MuseumId,
                paintType: PaintType, fromYear: FromYear, toYear: ToYear);

            if (CurrentPage > TotalPages && TotalPages > 0)
            {
                CurrentPage = TotalPages;
                NavigateToPage(true);
                return;
            }
        }
        catch (ApiException ex)
        {
            Logger.LogError(ex, "API Error loading paintings. Status: {StatusCode}", ex.StatusCode);
            errorMessage = $"Could not load paintings (status {ex.StatusCode}). Please try again.";
            pagedPaintings = new Pagination_1OfOfPaintingDtoAndApplicationAnd_0AndCulture_neutralAndPublicKeyToken_null
                { Data = new List<PaintingDto>(), Count = 0, PageIndex = CurrentPage, PageSize = PageSize };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading paintings");
            errorMessage = "An error occurred while loading paintings.";
            pagedPaintings = new Pagination_1OfOfPaintingDtoAndApplicationAnd_0AndCulture_neutralAndPublicKeyToken_null
                { Data = new List<PaintingDto>(), Count = 0, PageIndex = CurrentPage, PageSize = PageSize };
        }
        finally
        {
            isLoading = false;
        }

        StateHasChanged();
    }

    private void ApplySearch()
    {
        ActiveSearch = CurrentSearch;
        CurrentPage = 1;
        NavigateToPage();
    }

    private void ApplyFilters()
    {
        CurrentPage = 1;
        NavigateToPage();
    }

    private void ClearAllFilters()
    {
        ArtistId = null;
        GenreId = null;
        MuseumId = null;
        PaintTypeString = null;
        FromYear = null;
        ToYear = null;
        CurrentPage = 1;

        var q = new Dictionary<string, object?>
        {
            ["currentPage"] = "1",
            ["pageSize"] = PageSize.ToString(),
            ["activeSearch"] = string.IsNullOrWhiteSpace(ActiveSearch) ? null : ActiveSearch,
            ["currentSort"] = CurrentSort
        };
        var baseUri = NavigationManager.Uri.Split('?')[0];
        NavigationManager.NavigateTo(NavigationManager.GetUriWithQueryParameters(baseUri,
                q.Where(kv => kv.Value != null).ToDictionary(kv => kv.Key, kv => kv.Value)!),
            forceLoad: false, replace: true);
    }

    private void ClearSearch()
    {
        CurrentSearch = string.Empty;
        ActiveSearch = null;
        CurrentPage = 1;
        var q = new Dictionary<string, object?>
        {
            ["currentPage"] = "1",
            ["pageSize"] = PageSize.ToString(),
            ["currentSort"] = CurrentSort,
            ["artistId"] = ArtistId?.ToString(),
            ["genreId"] = GenreId?.ToString(),
            ["museumId"] = MuseumId?.ToString(),
            ["paintType"] = PaintTypeString,
            ["fromYear"] = FromYear?.ToString(),
            ["toYear"] = ToYear?.ToString()
        };
        var baseUri = NavigationManager.Uri.Split('?')[0];
        NavigationManager.NavigateTo(NavigationManager.GetUriWithQueryParameters(baseUri,
                q.Where(kv => kv.Value != null).ToDictionary(kv => kv.Key, kv => kv.Value)!),
            forceLoad: false, replace: true);
    }

    private void ChangePage(int pageNumber)
    {
        if (pageNumber < 1 || (TotalPages > 0 && pageNumber > TotalPages) || pageNumber == CurrentPage) return;
        CurrentPage = pageNumber;
        NavigateToPage();
    }

    private void NavigateToPage(bool isPageAdjustment = false)
    {
        var q = new Dictionary<string, object?>
        {
            ["currentPage"] = CurrentPage.ToString(),
            ["pageSize"] = PageSize.ToString(),
            ["activeSearch"] = string.IsNullOrWhiteSpace(ActiveSearch) ? null : ActiveSearch,
            ["currentSort"] = CurrentSort,
            ["artistId"] = ArtistId?.ToString(),
            ["genreId"] = GenreId?.ToString(),
            ["museumId"] = MuseumId?.ToString(),
            ["paintType"] = PaintTypeString,
            ["fromYear"] = FromYear?.ToString(),
            ["toYear"] = ToYear?.ToString()
        };
        var newUri = NavigationManager.GetUriWithQueryParameters(
            q.Where(kv => kv.Value != null).ToDictionary(kv => kv.Key, kv => kv.Value)!);
        if (NavigationManager.Uri != newUri || isPageAdjustment)
            NavigationManager.NavigateTo(newUri, forceLoad: false, replace: true);
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ApplySearch();
    }

    private async Task HandlePaintingDeleted(Guid paintingId)
    {
        Logger.LogInformation("Painting deleted: {PaintingId}", paintingId);
        Toast.Success("Painting deleted successfully.");
        await LoadPaintings();
    }

}
